DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_TIMEOUT_MS=18000

XAI_API_KEY=
XAI_IMAGE_API_URL=https://api.x.ai/v1/images/generations
XAI_IMAGE_DEFAULT_MODEL=grok-imagine-image-quality
XAI_IMAGE_TIMEOUT_MS=90000

COMFYUI_API_URL=https://comfy.destinypixel.com
COMFYUI_TIMEOUT_MS=180000
COMFYUI_POLL_INTERVAL_MS=1500
COMFYUI_Z_IMAGE_UNET=z_image_bf16.safetensors
COMFYUI_Z_IMAGE_CLIP=qwen_3_4b.safetensors
COMFYUI_Z_IMAGE_VAE=ae.safetensors
COMFYUI_Z_IMAGE_STEPS=20
COMFYUI_Z_IMAGE_CFG=4
COMFYUI_Z_IMAGE_SHIFT=3

# Optional: set this later when membership/auth is wired.
IMAGE_STUDIO_ACCESS_TOKEN=

# Optional locally: when these are unset, the app writes reports to work/local-db.json.
# Required in production for /english member registration/login and cloud progress.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
